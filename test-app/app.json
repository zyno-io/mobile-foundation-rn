{
  "expo": {
    "name": "FoundationTestApp",
    "slug": "foundation-test-app",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zyno.foundation.testapp",
      "deploymentTarget": "16.4"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.zyno.foundation.testapp"
    },
    "newArchEnabled": true,
    "plugins": [
      "expo-font",
      ["@sentry/react-native", { "organization": "test", "project": "test" }],
      [
        "@zyno-io/mobile-foundation-rn",
        {
          "androidBuildProperties": {
            "gradleProperties": {
              "org.gradle.jvmargs": "-Xmx2048m -XX:MaxMetaspaceSize=1024m"
            },
            "gradleWrapperProperties": {
              "networkTimeout": 60000
            }
          },
          "detox": {
            "allowCleartextTraffic": true
          }
        }
      ]
    ]
  }
}
